{
    "name": "typescript-starter-template",
    "version": "0.0.1",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "packageManager": "pnpm@11.10.0",
    "scripts": {
        "build": "tsup && tsc --emitDeclarationOnly && tsc-alias",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint .",
        "prepare": "husky",
        "format": "prettier --write .",
        "lint-staged": "lint-staged",
        "release": "release-it",
        "release:dry": "release-it --dry-run"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@release-it/conventional-changelog": "^11.0.1",
        "@types/node": "^26.1.1",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.5",
        "release-it": "^20.2.1",
        "tsc-alias": "^1.9.0",
        "tsup": "^8.5.1",
        "tsx": "^4.23.0",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "zod": "^4.4.3"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    }
}

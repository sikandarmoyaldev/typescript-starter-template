{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.detectIndentation": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll.eslint": "explicit"
    },

    // --- Clean Explorer Side-Panel Trimming ---
    "files.exclude": {
        "**/dist": true,
        "**/.git": true,
        "**/.next": true,
        "**/*.log": true,
        "**/.husky": true,
        "**/.turbo": true,
        "**/.DS_Store": true,
        "**/node_modules": true,
        "pnpm-debug.log*": true
    },

    // --- Search Engine Performance Optimization ---
    "search.exclude": {
        "**/dist": true,
        "**/.next": true,
        "**/.turbo": true,
        "**/.husky": true,
        "**/node_modules": true,
        "**/pnpm-lock.yaml": true
    },

    // --- File Nesting View Rules ---
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        ".env.local": ".env.*",
        "README.md": "*.md, LICENSE",
        "package.json": ".prettierrc, .prettierignore, .release-it.json, *.cjs, pnpm-*, *.mjs, *.ts, *.js, *.json"
    }
}
